{
  "hooks": {
    "sessionStart": [
      {
        "command": "python3 scripts/validate-plugin.py --quick"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "python3 scripts/validate-plugin.py --mcp",
        "matcher": "cursor-odoo-dev"
      }
    ],
    "sessionEnd": [
      {
        "command": "python3 scripts/validate-plugin.py --quick"
      }
    ]
  }
}
